# Copy to .env and fill in. NEVER commit .env.
# All keys load via pydantic-settings (core/config.py, future).

# --- OpenAI / LLM ---
# Get the key from platform.openai.com/api-keys. Never commit a real value here.
OPENAI_API_KEY=
# Optional: project / org pinning if you use multiple OpenAI projects.
OPENAI_PROJECT=
OPENAI_ORG=

# --- Mode flags (deny-by-default) ---
# Must be "paper" until the human explicitly approves "live".
TRADING_MODE=paper
# Kill-switch override; must remain "false" in normal operation.
KILL_SWITCH_OVERRIDE=false

# --- Market data ---
# Paper data source (CSV path or vendor key); broker creds stay UNSET until Stage 4.
MARKET_DATA_PROVIDER=csv
MARKET_DATA_PATH=./data/paper_feed

# --- OANDA (practice by default; live requires explicit human approval) ---
# Get the token from OANDA → Manage API Access. Never commit a real value here.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# --- FRED (free key from https://fredaccount.stlouisfed.org/apikey) ---
FRED_API_KEY=
# (Forex Factory community feed and GDELT Doc 2.0 need no keys.)

# --- Other broker creds (LEAVE BLANK until that adapter exists and is approved) ---
BROKER_PROVIDER=
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=

# --- Logging / accounting ---
LOG_LEVEL=INFO
USAGE_DB_PATH=./data/usage.db
