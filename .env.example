# Copy to .env and fill in. NEVER commit .env.
# All keys load via pydantic-settings (core/config.py, future).

# --- Anthropic / LLM ---
ANTHROPIC_API_KEY=
# Comma-separated. core/llm_client.py decides which headers an individual call needs
# (see required_beta_headers); this env var is just the union of allowed betas.
ANTHROPIC_BETA_HEADERS=compact-2026-01-12,context-management-2025-06-27

# --- Mode flags (deny-by-default) ---
# Must be "paper" until the human explicitly approves "live".
TRADING_MODE=paper
# Kill-switch override; must remain "false" in normal operation.
KILL_SWITCH_OVERRIDE=false

# --- Market data ---
# Paper data source (CSV path or vendor key); broker creds stay UNSET until Stage 4.
MARKET_DATA_PROVIDER=csv
MARKET_DATA_PATH=./data/paper_feed

# --- Broker (LEAVE BLANK until live trading is explicitly approved) ---
BROKER_PROVIDER=
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=

# --- Logging / accounting ---
LOG_LEVEL=INFO
USAGE_DB_PATH=./data/usage.db
